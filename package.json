{
  "name": "databaseproj",
  "version": "1.0.0",
  "description": "CS542 Project",
  "main": "index.js",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "db:up": "docker-compose up -d",
    "db:down": "docker-compose down",
    "dev:client": "npm run dev -w client",
    "dev:server": "npm run start:dev -w server",
    "dev": "npm run db:up && concurrently -n \"NEST,VITE\" -c \"magenta,cyan\" \"npm run dev:server\" \"npm run dev:client\"",
    "clean": "rm -rf node_modules package-lock.json apps/*/dist apps/*/node_modules",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "Yanding Yin",
  "license": "ISC",
  "dependencies": {
    "concurrently": "^9.2.1",
    "pg": "^8.20.0"
  }
}
